{
  "criteria": {
    "rubric_based_tool_use_quality_v1": {
      "threshold": 1.0,
      "judgeModelOptions": {
        "judgeModel": "gemini-2.5-flash",
        "numSamples": 3
      },
      "rubrics": [
        {
          "rubricId": "read_doc_called",
          "rubricContent": {
            "textProperty": "The agent called the read_doc tool."
          }
        },
        {
          "rubricId": "build_sheets_after_read",
          "rubricContent": {
            "textProperty": "The agent called build_sheets after read_doc."
          }
        }
      ]
    },
    "hallucinations_v1": {
      "threshold": 0.8,
      "judgeModelOptions": {
        "judgeModel": "gemini-2.5-flash",
        "numSamples": 3
      }
    },
    "extraction_self_consistency": {
      "threshold": 1.0
    },
    "extraction_faithfulness": {
      "threshold": 0.8
    },
    "extraction_classification": {
      "threshold": 1.0
    },
    "extraction_bookable_granularity": {
      "threshold": 1.0
    },
    "extraction_itemized_fidelity": {
      "threshold": 1.0
    },
    "extraction_tax_bucket_fidelity": {
      "threshold": 1.0
    },
    "extraction_bank_reconcile": {
      "threshold": 0.95
    }
  },
  "customMetrics": {
    "extraction_self_consistency": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_self_consistency"
      },
      "description": "Arithmetic self-consistency on read_doc output (reference-free)."
    },
    "extraction_faithfulness": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_faithfulness"
      },
      "description": "LLM judge reads source PDF + extraction (reference-free)."
    },
    "extraction_classification": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_classification"
      },
      "description": "Model correctly identifies file_kind and document_kind (data-driven)."
    },
    "extraction_bookable_granularity": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_bookable_granularity"
      },
      "description": "Hierarchy-scope cases must not over-extract supporting detail rows."
    },
    "extraction_itemized_fidelity": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_itemized_fidelity"
      },
      "description": "Itemized-scope cases must not collapse printed product lines."
    },
    "extraction_tax_bucket_fidelity": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_tax_bucket_fidelity"
      },
      "description": "Tax-bucket cases must emit SR+ZR rows with Xero-style descriptions."
    },
    "extraction_bank_reconcile": {
      "codeConfig": {
        "name": "ledgr_agent.eval.ledgr_light_metrics.extraction_bank_reconcile"
      },
      "description": "Bank statements must reconcile running balances after normalize."
    }
  },
  "metricsToRun": [
    "rubric_based_tool_use_quality_v1",
    "hallucinations_v1",
    "extraction_self_consistency",
    "extraction_faithfulness",
    "extraction_classification",
    "extraction_bookable_granularity",
    "extraction_itemized_fidelity",
    "extraction_tax_bucket_fidelity",
    "extraction_bank_reconcile"
  ],
  "metrics_to_run": [
    "rubric_based_tool_use_quality_v1",
    "hallucinations_v1",
    "extraction_self_consistency",
    "extraction_faithfulness",
    "extraction_classification",
    "extraction_bookable_granularity",
    "extraction_itemized_fidelity",
    "extraction_tax_bucket_fidelity",
    "extraction_bank_reconcile"
  ]
}
