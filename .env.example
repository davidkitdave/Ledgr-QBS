# === Environment ===
# LEDGR_ENV controls dev/prod behaviour:
#   dev  → uses AI Studio, prepends [dev] to bot status messages, dev Firestore namespace
#   prod → uses Vertex AI, no prefix, prod Firestore namespace
# Defaults to dev when unset.
LEDGR_ENV=dev

# ─── Slack (Ledgr-dev app) ────────────────────────────────────────────────────
# Tokens from the "Ledgr (dev)" Slack app (slack/manifest-dev.json).
# Dev slash command is /ledgr-dev (production Ledgr-QBS uses /ledgr).
# Never use production tokens here.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ─── Gemini models (single control surface) ───────────────────────────────────
# All extraction + agent lanes read these via invoice_processing/shared_libraries/model_config.py
LEDGR_MODEL_LITE=gemini-2.5-flash-lite
LEDGR_MODEL_STD=gemini-2.5-flash
# LEDGR_MODEL_CHAT=gemini-2.5-flash
# LEDGR_MODEL_READ=gemini-2.5-flash-lite
# Legacy alias (only used when LEDGR_MODEL_STD is unset):
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# Optional ADK SkillToolset playbooks (ledger-read, extraction-introspect, write-gated).
# LEDGR_CHAT_SKILLS=0

# ─── Extraction pipeline ─────────────────────────────────────────────────────
# Default: Understand (ADR-0011) — one multimodal Gemini call (faithful documents[] array).
# Legacy SOA extraction is quarantined: set LEDGR_LEGACY_SOA=1 with doc_type SOA only.
# Set LEDGR_CAPTURE_BOOK=1 to opt into the deprecated ADR-0014 Capture → Book → Verify
# two-call pipeline (experiments only — doubles API load).
# LEDGR_CAPTURE_BOOK=0
# LEDGR_LEGACY_SOA=0
# LEDGR_UNDERSTAND_EXTRACT=1

# ─── Firestore namespace (REQUIRED in dev — see ADR-0022) ─────────────────────
# Dev and prod share the GCP project + (default) Firestore database, so dev MUST
# set this prefix or a QA run will write into the SAME collections prod reads
# (clients, sessions, channels, ledgers, ...). With it set, dev writes dev_clients,
# dev_sessions, etc. Prod leaves it UNSET (bare collections). Applies to every
# top-level collection; subcollections inherit isolation from their parent.
LEDGR_FIRESTORE_NAMESPACE=dev

# (existing vars below — keep them)

# ─── Gemini / AI Studio (NO Vertex) ─────────────────────────────────────────
# Use AI Studio key in dev. Production reads GOOGLE_APPLICATION_CREDENTIALS via Secret Manager.


# ─── Google Cloud (Firestore for sessions + client profiles) ──────────────────
GOOGLE_CLOUD_PROJECT=ledgr-qbs
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # local only

# ─── Slack OAuth (Model B multi-workspace; leave blank for single-workspace) ──
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─── Cloud Run / server ───────────────────────────────────────────────────────
PORT=8080

# ─── Optional telemetry (GCS bucket for OTel traces; omit to disable) ─────────
# LOGS_BUCKET_NAME=gs://your-telemetry-bucket

# ─── Sentry trend logging (WS-6.4; omit to disable — all calls are no-op) ─────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=dev
