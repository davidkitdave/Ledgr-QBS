# === Environment ===
# LEDGR_ENV controls dev/prod behaviour:
#   dev  → uses AI Studio, prepends [dev] to bot status messages, dev Firestore namespace
#   prod → uses Vertex AI, no prefix, prod Firestore namespace
# Defaults to dev when unset.
LEDGR_ENV=dev

# ─── Slack (Ledgr-dev app) ────────────────────────────────────────────────────
# Tokens from the "Ledgr (dev)" Slack app (slack/manifest-dev.json).
# Never use production tokens here.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# ─── Model tier overrides ─────────────────────────────────────────────────────
# Set these to override per-env defaults.
# Defaults:
#   dev  → LITE=gemini-2.5-flash-lite, STD=gemini-2.5-flash  (AI Studio, US/global)
#   prod → LITE=gemini-2.5-flash,      STD=gemini-2.5-flash  (Vertex asia-southeast1, until flash-lite lands there)
# LEDGR_MODEL_LITE=gemini-2.5-flash-lite
# LEDGR_MODEL_STD=gemini-2.5-flash

# ─── Firestore namespace ──────────────────────────────────────────────────────
# Optional: prefix collection names so dev/prod can share a GCP project.
# Cleaner alternative: use a separate Firestore project per env.
# LEDGR_FIRESTORE_NAMESPACE=dev

# (existing vars below — keep them)

# ─── Gemini / AI Studio (NO Vertex) ─────────────────────────────────────────
# Use AI Studio key in dev. Production reads GOOGLE_APPLICATION_CREDENTIALS via Secret Manager.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-ai-studio-key-here

# ─── Google Cloud (Firestore for sessions + client profiles) ──────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # local only

# ─── Slack OAuth (Model B multi-workspace; leave blank for single-workspace) ──
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─── Cloud Run / server ───────────────────────────────────────────────────────
PORT=8080

# ─── Optional telemetry (GCS bucket for OTel traces; omit to disable) ─────────
# LOGS_BUCKET_NAME=gs://your-telemetry-bucket
